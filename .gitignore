# Dependencies — always regenerated from package-lock.json
node_modules/

# Secrets — the whole point of .env.example is that .env never gets committed
.env
.env.local
.env.*.local

# Build output — regenerated by tsc / vite build
dist/
build/

# Prisma's generated client lives in node_modules, so nothing extra needed,
# but if you ever set a custom output path, ignore it here

# Logs
*.log
npm-debug.log*

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# LocalStack — if you ever switch from named volumes to a bind mount
# (e.g. ./volume/), its data dir goes here. With the current compose file
# using named volumes, Docker keeps data outside the repo, so nothing needed.

# Vite cache (once the admin app exists)
.vite/

.history