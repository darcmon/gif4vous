NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://gif:gif@localhost:5432/gif_library

# LocalStack (dev). In production: delete S3_ENDPOINT, use real AWS creds.
S3_BUCKET=gif-library
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Any long random string; generate with: openssl rand -hex 24
ADMIN_TOKEN=replace-me-with-a-long-random-string
